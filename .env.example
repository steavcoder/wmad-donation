# Copy to .env.local for development. Set the same keys in Vercel → Project → Settings → Environment Variables.

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# Pooled connection string for serverless (Prisma at runtime).
# Examples: Neon pooled URL, Supabase "Transaction" pooler, Vercel Postgres, or
# any Postgres with PgBouncer in front. See docs/vercel-environment-variables.md.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Optional: direct (non-pooled) URL for Prisma Migrate CLI (Neon recommends this
# for `npx prisma migrate deploy` / baseline). If you add directUrl to schema.prisma,
# set DIRECT_URL here too. Vercel builds do not run migrations; run deploy locally/CI.
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
# Strong random secret for signing JWTs (e.g. openssl rand -base64 32).
# Never commit real values; never expose to the browser.
JWT_SECRET="replace-with-long-random-string-min-32-chars"

# -----------------------------------------------------------------------------
# Node (optional; usually set automatically)
# -----------------------------------------------------------------------------
# NODE_ENV=development
